<UserControl x:Class="WimyGit.UserControls.WorktreeTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WimyGit.UserControls"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="400" MinHeight="300">
    <UserControl.DataContext>
        <local:WorktreeTabViewModel/>
    </UserControl.DataContext>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <Button Grid.Row="0" Margin="5" Padding="10,8,10,8" HorizontalAlignment="Left"
                Command="{Binding AddWorktreeCommand}" Content="Add Worktree" />

        <ListView Grid.Row="1" Name="worktreeList"
                  ItemsSource="{Binding WorktreeItems}"
                  SelectedValue="{Binding SelectedWorktreeItem}">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="*" DisplayMemberBinding="{Binding IsMainMark}" Width="30"/>
                    <GridViewColumn Header="Path" DisplayMemberBinding="{Binding Path}" Width="300"/>
                    <GridViewColumn Header="Branch" DisplayMemberBinding="{Binding Branch}" Width="150"/>
                    <GridViewColumn Header="Commit" DisplayMemberBinding="{Binding CommitHash}" Width="80"/>
                    <GridViewColumn Header="Locked" DisplayMemberBinding="{Binding Locked}" Width="60"/>
                </GridView>
            </ListView.View>
            <ListView.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Open in Explorer" Command="{Binding OpenInExplorerCommand}"/>
                    <MenuItem Header="Open in new repository tab" Command="{Binding OpenInNewRepositoryTabCommand}"/>
                    <MenuItem Header="Remove" Command="{Binding RemoveWorktreeCommand}"/>
                </ContextMenu>
            </ListView.ContextMenu>
        </ListView>

        <Label Grid.Row="2" Content="Detail:" HorizontalAlignment="Left" VerticalAlignment="Bottom"/>

        <TextBlock Grid.Row="3" Margin="5,0,5,5" TextWrapping="Wrap">
            <TextBlock.Text>
                <MultiBinding StringFormat="{}{0}  /  {1}  /  {2}  {3}">
                    <Binding ElementName="worktreeList" Path="SelectedItem.Path"/>
                    <Binding ElementName="worktreeList" Path="SelectedItem.Branch"/>
                    <Binding ElementName="worktreeList" Path="SelectedItem.CommitHash"/>
                    <Binding ElementName="worktreeList" Path="SelectedItem.Locked"/>
                </MultiBinding>
            </TextBlock.Text>
        </TextBlock>
    </Grid>
</UserControl>
