<Window x:Class="WimyGit.Views.NewBranchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WimyGit.Views"
        mc:Ignorable="d"
        Title="New Branch" Height="315" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F5F5"
        FocusManager.FocusedElement="{Binding ElementName=BranchName}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Content Area -->
        <StackPanel Grid.Row="0" Margin="24,20,24,16">
            <TextBlock Text="Create New Branch" FontSize="16" FontWeight="SemiBold"
                       Foreground="#1A1A1A" Margin="0,0,0,20"/>

            <TextBlock Text="Commit" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="CommitId" Style="{StaticResource ReadonlyField}" Margin="0,0,0,4"/>
            <TextBox x:Name="CommitMessage" Style="{StaticResource ReadonlyField}" Margin="0,0,0,14"/>

            <TextBlock Text="Branch Name" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="BranchName" Style="{StaticResource InputField}" Margin="0,0,0,14"/>

            <CheckBox x:Name="NeedCheckout" Content="Checkout after creation"
                      FontSize="13" Foreground="#444444" Cursor="Hand"/>
        </StackPanel>

        <!-- Footer -->
        <Border Grid.Row="1" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Background="White">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="16,10">
                <Button Content="Cancel" Style="{StaticResource CancelButton}"
                        Margin="0,0,8,0" Click="OnCancel"/>
                <Button Content="Create" Style="{StaticResource CreateButton}"
                        IsDefault="True" Click="OnCreate"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
