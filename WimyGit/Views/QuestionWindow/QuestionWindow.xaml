<Window x:Class="WimyGit.UI.QuestionWindow.QuestionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WimyGit.UI.QuestionWindow"
        mc:Ignorable="d"
        Title="Question" Height="230" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F5F5">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <TextBlock x:Name="Information" Margin="24,14" FontSize="15" FontWeight="SemiBold"
                       Foreground="#1A1A1A" TextTrimming="CharacterEllipsis"/>
        </Border>

        <!-- Content Area -->
        <StackPanel Grid.Row="1" Margin="24,16,24,16">
            <TextBlock x:Name="Question" Style="{StaticResource FieldLabel}" FontSize="12"
                       TextWrapping="Wrap" Margin="0,0,0,8"/>
            <TextBox x:Name="Answer" Style="{StaticResource InputField}"/>
        </StackPanel>

        <!-- Footer -->
        <Border Grid.Row="2" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Background="White">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="16,10">
                <Button Content="Cancel" Style="{StaticResource CancelButton}"
                        Margin="0,0,8,0" Click="OnCancel"/>
                <Button Content="OK" Style="{StaticResource CreateButton}"
                        IsDefault="True" Click="OnOK"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
