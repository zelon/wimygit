<Window x:Class="WimyGit.Views.NewWorktreeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Add Worktree" Height="330" Width="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F5F5"
        FocusManager.FocusedElement="{Binding ElementName=WorktreePath}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Content Area -->
        <StackPanel Grid.Row="0" Margin="24,20,24,16">
            <TextBlock Text="Add Worktree" FontSize="16" FontWeight="SemiBold"
                       Foreground="#1A1A1A" Margin="0,0,0,20"/>

            <TextBlock Text="Path" Style="{StaticResource FieldLabel}"/>
            <Grid Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="WorktreePath" Grid.Column="0" Style="{StaticResource InputField}" Margin="0,0,6,0"/>
                <Button Grid.Column="1" Content="Browse" Padding="10,6" Click="OnBrowse"/>
            </Grid>

            <TextBlock Text="Branch Name" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="BranchName" Style="{StaticResource InputField}" Margin="0,0,0,14"/>

            <CheckBox x:Name="CreateNewBranch" Content="Create new branch (-b)"
                      FontSize="13" Foreground="#444444" Cursor="Hand"
                      Checked="OnCreateNewBranchChanged" Unchecked="OnCreateNewBranchChanged"/>
        </StackPanel>

        <!-- Footer -->
        <Border Grid.Row="1" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Background="White">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="16,10">
                <Button Content="Cancel" Style="{StaticResource CancelButton}"
                        Margin="0,0,8,0" Click="OnCancel"/>
                <Button Content="Add" Style="{StaticResource CreateButton}"
                        IsDefault="True" Click="OnAdd"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
